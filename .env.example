# ============================================================
# Environment Variables — copy to .env and fill in real values
# ============================================================

# ─── US Region ────────────────────────────────────────────────
REGION_US_ID=us
DB_US_USER=postgres
DB_US_PASSWORD=changeme_us
DB_US_NAME=incidents
DB_US_HOST=db-us
DB_US_PORT=5432
REGION_US_PORT=8001
REGION_US_PEER_URLS=http://region-eu:8000,http://region-apac:8000

# ─── EU Region ────────────────────────────────────────────────
REGION_EU_ID=eu
DB_EU_USER=postgres
DB_EU_PASSWORD=changeme_eu
DB_EU_NAME=incidents
DB_EU_HOST=db-eu
DB_EU_PORT=5432
REGION_EU_PORT=8002
REGION_EU_PEER_URLS=http://region-us:8000,http://region-apac:8000

# ─── APAC Region ──────────────────────────────────────────────
REGION_APAC_ID=apac
DB_APAC_USER=postgres
DB_APAC_PASSWORD=changeme_apac
DB_APAC_NAME=incidents
DB_APAC_HOST=db-apac
DB_APAC_PORT=5432
REGION_APAC_PORT=8003
REGION_APAC_PEER_URLS=http://region-us:8000,http://region-eu:8000

# ─── Replication ──────────────────────────────────────────────
# How often (seconds) each region pushes updates to its peers
REPLICATION_INTERVAL=5
